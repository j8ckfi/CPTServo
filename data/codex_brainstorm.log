45:from __future__ import annotations
46:
47:import json
48:from pathlib import Path
49:from typing import ClassVar
50:
51:import yaml
52:
53:# ---------------------------------------------------------------------------
54:# Default gain constants (Z-N seed + manual refinement; documented above)
55:# ---------------------------------------------------------------------------
56:_DEFAULT_KP: float = 1000.0   # Hz_correction per dimensionless error
57:_DEFAULT_KI: float = 50000.0  # Hz_correction / (s · dimensionless error)
58:_DEFAULT_DT: float = 0.001    # s — 1 kHz control update rate
59:
60:_RECIPE_PATH = Path(__file__).parent.parent.parent.parent / "configs" / "v1_recipe.yaml"
