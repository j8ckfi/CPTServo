59-    n_warmup_steps: int = 5_000,
60-    rng_seed: int = 12345,
61-    use_lockin_path: bool = True,
62-) -> dict[str, Any]:
63-    """Closed- or open-loop run with vectorised disturbance.
64-
65-    When ``use_lockin_path=True`` (default), uses the FM-modulation +
66-    photodetector + lock-in demodulator chain. Shot noise from the twin's
67-    photodetector_signal() propagates physically through the lock-in to
68-    become servo error noise — no hand-calibrated injection needed.
69-
70-    When ``use_lockin_path=False``, uses ci directly (faster but
71-    deterministic). Only useful for sanity-checking dynamics in absence of
72-    photon noise.
73-    """
74-    dt = 1.0 / physics_rate_Hz
75-    decimation = int(round(physics_rate_Hz / decimation_rate_Hz))
76-    n_dec = int(round(duration_s * decimation_rate_Hz))
