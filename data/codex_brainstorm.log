63:class PIController:
64:    """Hand-tuned PI controller for the CPT-clock RF lock loop.
65:
66:    The controller acts on the dimensionless lock-in error signal ``e`` and
67:    outputs a two-element control tuple ``(laser_correction_Hz,
68:    rf_correction_Hz)``.  In v1 only the RF correction is non-zero; the laser
69:    detuning correction is always 0.
70:
71:    Gain tuning rationale (inline)
72:    --------------------------------
73:    Z-N ultimate-gain experiment on the clean scenario (see module docstring)
74:    yields ``Ku ≈ 2.0``, ``Tu ≈ 0.05 s``.  Classic Z-N PI:
75:    ``kp = 0.45*Ku = 0.90``, ``ki = 0.54*Ku/Tu = 21.6``.  Manual refinement
76:    reduces ki to 10.0 to suppress integrator wind-up on slow thermal ramps
77:    and kp to 1.0 to avoid noise amplification.  These gains give
78:    ``sigma_y(tau=1 s) / open_loop_sigma_y < 0.7`` on clean and
79:    ``ratio_pi_to_floor < 1.5`` on the white-FM predicted floor — satisfying
80:    the M4 gate criteria.
81:
82:    Args:
83:        kp: Proportional gain (Hz_correction per dimensionless error).
84:        ki: Integral gain (Hz_correction / second per error).
85:        control_dt_s: Control update period in seconds.
86:    """
87:
88:    # Class-level sentinel for ZN documentation
89:    _ZN_KU: ClassVar[float] = 2.0
90:    _ZN_TU: ClassVar[float] = 0.05
91:
92:    def __init__(
93:        self,
94:        kp: float = _DEFAULT_KP,
