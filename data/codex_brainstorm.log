1:"""FM modulation and lock-in demodulation for CPT clock readout.
2:
3:Implements the standard FM lock-in technique used in chip-scale CPT clocks: the
4:RF (or laser) frequency is sinusoidally modulated at f_mod; the photodetector
5:signal is then demodulated at f_mod to produce an error signal proportional to
6:the slope of the CPT resonance.  At resonance the error is zero; off-resonance
7:the sign gives the direction of the correction.
8:
9:References
10:----------
11:Kitching, J. (2018). Chip-scale atomic devices.
12:    *Applied Physics Reviews*, 5, 031302.
13:"""
14:
15:from __future__ import annotations
16:
17:import math
18:
19:import torch
20:from torch import Tensor
21:
22:
23:class LockIn:
24:    """FM modulation and lock-in demodulator.
25:
26:    Parameters configure the modulation frequency, depth, and the lowpass
27:    time-constant of the single-pole IIR demodulator.
28:
29:    Typical usage::
30:
31:        lockin = LockIn(modulation_freq_Hz=100.0,
32:                        modulation_depth_Hz=1000.0,
33:                        demod_lowpass_tc_s=1e-3)
34:        t = torch.linspace(0, 0.01, 100)
35:        mod = lockin.modulate(t)          # frequency offsets
36:        err = lockin.demod(signal, 10000.0)  # error signal from 100-sample window
37:    """
38:
39:    # ---------------------------------------------------------------------------
40:
41:    def __init__(
42:        self,
43:        modulation_freq_Hz: float = 100.0,
44:        modulation_depth_Hz: float = 1000.0,
45:        demod_lowpass_tc_s: float = 1.0e-3,
46:    ) -> None:
47:        """Initialise LockIn.
48:
49:        Args:
50:            modulation_freq_Hz: Modulation (dither) frequency in Hz.
51:            modulation_depth_Hz: Peak frequency deviation of the FM dither (Hz).
52:            demod_lowpass_tc_s: Time constant of the single-pole IIR lowpass
53:                filter applied after mixing (seconds).
54:        """
55:        self.f_mod = modulation_freq_Hz
56:        self.depth = modulation_depth_Hz
57:        self.tc = demod_lowpass_tc_s
58:
59:    # ---------------------------------------------------------------------------
60:
61:    def modulate(self, t: Tensor) -> Tensor:
62:        """Return instantaneous FM modulation offset at times t.
63:
64:        Args:
65:            t: Time array (any shape), in seconds.
66:
67:        Returns:
68:            Tensor of same shape as t; values in Hz.
69:        """
70:        return self.depth * torch.sin(2.0 * math.pi * self.f_mod * t)
71:
72:    # ---------------------------------------------------------------------------
73:
74:    def demod(
75:        self,
76:        signal_window: Tensor,
77:        sample_rate_Hz: float,
78:        carrier_phase_offset: float = 0.0,
79:    ) -> Tensor:
80:        """Demodulate a photodetector signal window.
81:
82:        Multiplies by the reference sin(2*pi*f_mod*t + phase) then applies a
83:        single-pole IIR lowpass filter with time-constant self.tc.  Returns the
84:        final (steady-state) in-phase amplitude, which is proportional to the
85:        lock-loop error signal.
86:
87:        Args:
88:            signal_window: (B, N) real-valued photodetector time series.  N is
89:                the number of samples in the window.
90:            sample_rate_Hz: Sample rate of the signal in Hz.
91:            carrier_phase_offset: Phase offset of the demodulation carrier
92:                (radians).  Use 0.0 for standard in-phase demod.
93:
94:        Returns:
95:            (B,) demodulated error signal (in-phase amplitude after lowpass).
96:        """
97:        B, N = signal_window.shape
98:        dt = 1.0 / sample_rate_Hz
99:
100:        # Build time vector for this window (relative to start of window = t=0)
101:        t = torch.arange(N, dtype=signal_window.dtype, device=signal_window.device) * dt
102:
103:        # Reference carrier: sin(2*pi*f_mod*t + phase)
104:        carrier = torch.sin(
105:            2.0 * math.pi * self.f_mod * t + carrier_phase_offset
106:        )  # (N,)
107:
108:        # Multiply signal by carrier — same for every batch element
109:        mixed = signal_window * carrier.unsqueeze(0)  # (B, N)
110:
111:        # Single-pole IIR lowpass: alpha = dt / (tc + dt)
112:        alpha = dt / (self.tc + dt)
113:
114:        # Run IIR filter across the N dimension
115:        # y[n] = alpha * x[n] + (1-alpha) * y[n-1]
116:        # We iterate; N is typically small (100–1000 samples).
117:        y = torch.zeros(B, dtype=signal_window.dtype, device=signal_window.device)
118:        for n in range(N):
119:            y = alpha * mixed[:, n] + (1.0 - alpha) * y
120:
121:        return y
